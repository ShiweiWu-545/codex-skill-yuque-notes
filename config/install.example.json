{
  "install": {
    "install_node_dependencies": true
  },
  "skill": {
    "name": "yuque-notes",
    "source_dir": "skill"
  },
  "codex": {
    "codex_home": "~/.codex"
  },
  "browser": {
    "repo_url": "https://www.yuque.com/<group-login>/<book-slug>",
    "chrome_user_data_dir": "%LOCALAPPDATA%/Google/Chrome/User Data",
    "chrome_profile_directory": "Default",
    "channel": "chrome"
  },
  "mcp": {
    "server_name": "yuque-mcp",
    "project_root": "../yuque-mcp-src",
    "command": "python",
    "args": [
      "-m",
      "yuque_mcp.server"
    ],
    "env": {
      "YUQUE_SPACE_SUBDOMAIN": "www",
      "DEFAULT_API_TOKEN": "<default_api_token>",
      "DEFAULT_GROUP_LOGIN": "<default_group_login>",
      "DEFAULT_BOOK_SLUG": "<default_book_slug>"
    }
  }
}
